 */
function getAppLinks() {
  try {
    var ss = SpreadsheetApp.openById(REQUEST_SHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.LINKS);
    
    if (!sheet) {
      // シートがない場合は初期化
      sheet = ss.insertSheet(SHEET_NAMES.LINKS);
      // ヘッダーとデフォルト値を書き込む
      var defaultData = [
        ['ID', 'URL', '説明'],
        ['salesApp', 'https://script.google.com/a/macros/nne.co.jp/s/AKfycbzkfxV6eBLjc3eaZbmSDuIoL9Dt2VdZVHoMheREBnGxlWmnvhzPRN4Y4zde29rAz2BF/exec', '営業用日報システム Webアプリ'],
        ['salesDB', 'https://docs.google.com/spreadsheets/d/1CJchjuO03CB0OYmyzdtaOq3N71fRXddG7QBSCJPn1GM/edit?gid=0#gid=0', '営業用日報システム DB'],
        ['generalApp', 'https://script.google.com/a/macros/nne.co.jp/s/AKfycbzlklzX0RHvDCfyOxwUQVSTqgZSFtYpeKRJLybqIE_-A3qTGEShsww2vjNnbGJ_2T5W/exec', '一般経費精算システム Webアプリ'],
        ['generalDB', 'https://docs.google.com/spreadsheets/d/15PGONpnqj6UDZa5076nXvKa2sUTg-_XFxHMDjBcgBFM/edit?gid=0#gid=0', '一般経費精算システム データ用DB'],
        ['accountingApp', 'https://script.google.com/a/macros/nne.co.jp/s/AKfycbyVsHGzQF9PYvTWG2f4sOq12bHj0iHLR9kjERZIMQahwz7HfqNcoh5Vp8hEeJVGiLQc0w/exec', '経理用 支払処理アプリ Webアプリ'],
        ['accountingDB', 'https://docs.google.com/spreadsheets/d/17WAK08P8zHyfwgbnsXR135XwabbuDGA2BWWu3q1VU70/edit?gid=0#gid=0', '経理用 支払処理アプリ DB']
      ];
      sheet.getRange(1, 1, defaultData.length, defaultData[0].length).setValues(defaultData);
      sheet.hideSheet(); // 普段は隠しておく
    }
    
    var data = getSheetData_(sheet);
    var links = {};
    data.forEach(function(row) {
      links[row.ID] = row.URL;
    });
    
    return { status: 'success', links: links };
  } catch (e) {
    Logger.log('getAppLinks Error: ' + e);
    return { status: 'error', message: 'リンクの取得に失敗しました: ' + e.message, links: {} };
  }
}

/**
 * (v13 新規) アプリのリンクを保存する
 */
function saveAppLinks(linksToSave) {
  // 管理者かどうかを再チェック
  var userInfo = getUserInfo_();
  if (!userInfo.isAdmin) {
    return { status: 'error', message: '保存権限がありません。' };
  }
  
  try {
    var ss = SpreadsheetApp.openById(REQUEST_SHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.LINKS);
    
    if (!sheet) {
      throw new Error('Linksシートが見つかりません。');
    }
    
    var range = sheet.getDataRange();
    var values = range.getValues();
    var headers = values.shift(); // ヘッダー
    
    var idCol = headers.indexOf('ID');
    var urlCol = headers.indexOf('URL');
    
    // values (データ行のみ) をループして更新
    var updated = false;
    for (var i = 0; i < values.length; i++) {
      var id = values[i][idCol];
      if (linksToSave[id]) {
        // GASの行インデックスは1-based、valuesのインデックスは0-basedなので、+2する
        sheet.getRange(i + 2, urlCol + 1).setValue(linksToSave[id]);
        updated = true;
      }
    }
    
    if (!updated) {
      throw new Error('更新対象のIDが見つかりませんでした。');
    }
    
    return { status: 'success', message: 'URLを更新しました。' };
  } catch (e) {
    Logger.log('saveAppLinks Error: ' + e);
    return { status: 'error', message: 'リンクの保存に失敗しました: ' + e.message };
  }
}


/**
 * (HELPER) 汎用: シートデータをオブジェクト配列に変換
 */
function getSheetData_(sheet) {
  if (!sheet) {
    Logger.log('getSheetData_: 対象のシートが見つかりません。');
    return [];
  }
  if (sheet.getLastRow() < 2 || sheet.getLastColumn() < 1) {
    if (sheet.getLastRow() === 1) return [];
    return [];
  }
  
  var lastRow = sheet.getLastRow();
  var lastCol = sheet.getLastColumn();
  
  var data = sheet.getRange(1, 1, lastRow, lastCol).getValues();
  var headers = data.shift(); 
  
  var result = data.map(function(row) {
    var obj = {};
    headers.forEach(function(header, index) {
      if (row[index] instanceof Date) {
         obj[header] = Utilities.formatDate(row[index], Session.getScriptTimeZone(), 'yyyy/MM/dd HH:mm:ss');
      } else {
        obj[header] = row[index];
      }
    });
    return obj;
  });
  
  return result;
}
