/**
 * WebアプリのGETリクエストハンドラ
 */
function doGet(e) {
  var ui = HtmlService.createTemplateFromFile('manual.html');
  
  // ユーザー情報をHTML側に渡す
  var userInfo = getUserInfo_();
  ui.userInfo = JSON.stringify(userInfo);
  
  return ui.evaluate()
    .setTitle('利用者マニュアル')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

/**
 * ログインユーザーの情報を取得
 * (v13 修正: isAdminフラグを追加)
 */
function getUserInfo_() {
  var email = Session.getEffectiveUser().getEmail();
  var name = 'ゲスト';
  var isAccounting = false;

  try {
    var ss = SpreadsheetApp.openById(MASTER_DB_ID);
    var data = getSheetData_(ss.getSheetByName('社員マスタ'));

    for (var i = 0; i < data.length; i++) {
      if (data[i]['アドレス'] === email) {
        name = data[i]['社員名'];
        isAccounting = data[i]['経理アプリアクセス'] === '有';
        break;
      }
    }
  } catch (e) {
    Logger.log('getUserInfo_ Error: ' + e);
  }

  // (v13) 管理者かどうかを判定
  var isAdmin = ADMIN_USERS.indexOf(email) > -1;

  return { name: name, email: email, isAdmin: isAdmin, isAccounting: isAccounting };
}

/**
 * (クライアントから呼び出し) 修正要望をスプレッドシートに送信する
 * (v12 修正: 依頼者情報を削除)
 */
function submitRequest(requestData) {
  try {
    var ss = SpreadsheetApp.openById(REQUEST_SHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.REQUESTS); // (v13) シート名変数を使用
    
    var status = '受付済';
    var requestDate = new Date();
    
    // スプレッドシートに行を追加 (v12 修正: 依頼者情報を削除)
    // (ヘッダー: 受付日時, タイトル, 詳細, ステータス)
    sheet.appendRow([
      requestDate,
      requestData.title,
      requestData.detail,
      status
    ]);
    
    // 管理者へメール通知 (v12 修正: 依頼者情報を削除)
    var userInfo = getUserInfo_(); // (v12) 誰からのメールか分かるようにするため再取得
    
    MailApp.sendEmail({
      to: ADMIN_EMAIL,
      subject: '[マニュアル修正要望] ' + requestData.title,
      body: 'マニュアルの修正要望が届きました。\n' +
            '（送信者: ' + userInfo.name + ' / ' + userInfo.email + '）\n\n' + // (v12) メール本文には送信者情報を記載
            '受付日時: ' + Utilities.formatDate(requestDate, Session.getScriptTimeZone(), 'yyyy/MM/dd HH:mm') + '\n' +
            'ステータス: ' + status + '\n' +
            'タイトル: ' + requestData.title + '\n\n' +
            '詳細:\n' + requestData.detail + '\n\n' +
            'スプレッドシートで内容を確認してください:\n' +
            ss.getUrl()
    });
    
    return { status: 'success', message: '修正要望を送信しました。' };
  } catch (e) {
    Logger.log('submitRequest Error: ' + e);
    return { status: 'error', message: '送信に失敗しました: ' + e.message };
  }
}

/**
 * (クライアントから呼び出し) 修正要望の一覧を取得する
 */
function getRequestList() {
  try {
    var ss = SpreadsheetApp.openById(REQUEST_SHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAMES.REQUESTS); // (v13) シート名変数を使用
    
    var data = getSheetData_(sheet);
    
    // 最新のものが上にくるように逆順にする
    return { status: 'success', data: data.reverse() };
  } catch (e) {
    Logger.log('getRequestList Error: ' + e);
    return { status: 'error', message: '一覧の取得に失敗しました: ' + e.message, data: [] };
  }
}

