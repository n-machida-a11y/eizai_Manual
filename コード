// 2. 社員マスタ（名前取得用）
var MASTER_DB_ID = '1CJchjuO03CB0OYmyzdtaOq3N71fRXddG7QBSCJPn1GM';
// 3. 要望受付時の通知先メールアドレス
var ADMIN_EMAIL = 'n-machida@race-number.co.jp';
// 4. (v13) マニュアル管理者（URL編集権限）
